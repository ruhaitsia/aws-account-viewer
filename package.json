{
  "name": "aws-account-viewer",
  "version": "1.0.0",
  "description": "AWS Account Viewer - Cross-platform desktop app for viewing AWS account resources",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build:all": "npm run build:main && npm run build:preload && npm run build:renderer",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"electron .\"",
    "electron:start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1030.0",
    "@aws-sdk/client-cloudwatch": "^3.1030.0",
    "@aws-sdk/client-cost-explorer": "^3.1030.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/client-ec2": "^3.1030.0",
    "@aws-sdk/client-ecs": "^3.1030.0",
    "@aws-sdk/client-eks": "^3.1030.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1030.0",
    "@aws-sdk/client-iam": "^3.1030.0",
    "@aws-sdk/client-lambda": "^3.1030.0",
    "@aws-sdk/client-rds": "^3.1030.0",
    "@aws-sdk/client-route-53": "^3.1030.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/client-sns": "^3.1030.0",
    "@aws-sdk/client-sqs": "^3.1030.0",
    "@aws-sdk/client-sts": "^3.1030.0",
    "antd": "^5.0.0",
    "json2csv": "^6.0.0-alpha.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
